{
  "name": "ve-video-converter",
  "version": "1.1.0",
  "description": "VE Video Converter - WebM to MP4",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --exec electron . --watch . --ext js,html,css",
    "build": "electron-builder",
    "build:win": "electron-builder --win portable",
    "build:win:portable": "electron-builder --win portable",
    "build:mac": "electron-builder --mac",
    "build:mac:zip": "electron-builder --mac --config.mac.target=zip",
    "build:mac:signed": "electron-builder --mac",
    "build:mac:zip:signed": "electron-builder --mac --config.mac.target=zip",
    "build:all": "electron-builder --win --mac"
  },
  "keywords": [
    "webm",
    "mp4",
    "converter",
    "ffmpeg"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fluent-ffmpeg": "^2.1.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.ve.videoconverter",
    "productName": "VE Video Converter",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/ffprobe-static/**/*"
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "converter.js",
      "index.html",
      "styles.css",
      "icon.png",
      "icon.ico",
      "node_modules/**/*",
      "!node_modules/**/*.{md,ts,map}",
      "!node_modules/.bin"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.utilities",
      "identity": null
    }
  }
}
